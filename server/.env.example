# ─── Environment ───
NODE_ENV=production
PORT=10000

# ─── MongoDB ───
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/learnsmart?retryWrites=true&w=majority

# ─── JWT ───
ACCESS_TOKEN_SECRET=<random-string-at-least-32-chars>
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY_DAYS=7

# ─── OAuth: Google ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://YOUR_RENDER_APP.onrender.com/api/auth/google/callback

# ─── OAuth: GitHub ───
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://YOUR_RENDER_APP.onrender.com/api/auth/github/callback

# ─── Client ───
CLIENT_URL=https://YOUR_VERCEL_APP.vercel.app

# ─── AI (OpenRouter) ───
OPENROUTER_API_KEY=sk-or-v1-<your-key>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# ─── ChromaDB ───
# Run separately via Docker or another Render service
CHROMA_URL=http://localhost:8000

# ─── Upload ───
UPLOAD_MAX_SIZE_MB=50
