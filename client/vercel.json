{
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://<YOUR_DO_APP>.ondigitalocean.app/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
